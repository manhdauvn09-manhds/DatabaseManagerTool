# ---- NextAuth (Google provider) ----
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret

# Random base64 string. Generate: `openssl rand -base64 32`
AUTH_SECRET=replace_me_with_random_base64

# Set "true" when running behind a reverse proxy / non-localhost host.
AUTH_TRUST_HOST=true

# Public URL of the app — phải trùng host người dùng truy cập.
# Required cho: NextAuth OAuth callback + Origin/Referer check ở /api/connect.
AUTH_URL=https://DBManager.allin1site.com

# ---- Sign-in allowlist (REQUIRED — fail-closed by default) ----
# Set at least one of ALLOWED_EMAILS or ALLOWED_EMAIL_DOMAINS, OR set AUTH_ALLOW_ANY=true.
# If none configured, ALL sign-in attempts are rejected.
ALLOWED_EMAILS=
ALLOWED_EMAIL_DOMAINS=
# DEV/STAGING ONLY — allow any Google account to sign in (overrides allowlist).
AUTH_ALLOW_ANY=false

# ---- Network / origin hardening ----
# When deployed behind Cloudflare, set true to reject requests missing CF-Connecting-IP header.
# Pair with iptables/ufw that restricts inbound 443 to Cloudflare IP ranges.
REQUIRE_CLOUDFLARE=false

# Allow connecting to private/LAN DB hosts (10.0.0.0/8, 172.16/12, 192.168/16, fc00::/7).
# Loopback (127.0.0.1) and 169.254 (cloud metadata) are ALWAYS blocked regardless.
ALLOW_PRIVATE_HOSTS=false

# MSSQL: trust server certificate (self-signed). Default false (strict TLS).
MSSQL_TRUST_SERVER_CERT=false

# Strict TLS cert verification for mysql/pg when ssl=true.
# false (default) = encrypt but accept self-signed; true = full chain verification.
DB_SSL_STRICT=false

# ---- Session ----
# How long a sign-in stays valid (seconds). Default 24h. Min 60.
SESSION_MAXAGE_SEC=86400

# ---- Connection lifecycle tunables ----
# Max concurrent /api/connect DB test attempts across ALL users (global cap).
DB_MAX_CONCURRENT_CONNECTS=10
# Max concurrent /api/connect attempts PER user (fairness; prevents one user from
# starving the global pool).
DB_MAX_PER_USER_CONNECTS=2

# Connection pooling (opt-in). Default false = fresh connect per request (proven path).
# When true, one driver handle per connectionId is reused across requests (faster
# browsing) with a per-id serial mutex + idle eviction. Holds the credential in
# driver memory until idle close (DB_POOL_IDLE_MS).
DB_POOL_ENABLED=false
DB_POOL_IDLE_MS=30000
# In-memory connection record TTL (ms). Default 5 min.
CONNECTION_TTL_MS=300000
# In-memory record cap. Oldest evicted on overflow.
CONNECTION_MAX_RECORDS=1000

# ---- Saved connections (server-encrypted at rest) ----
# Persistent file holding encrypted profile blobs. Default /data/saved-connections.json
# (with docker volume `dbmanager_data` mounted at /data).
SAVED_CONNECTIONS_PATH=/data/saved-connections.json

# RSA keypair persistence (defense-in-depth password encryption).
# If VAULT_MASTER_SECRET is set, the keypair is encrypted at rest here so it
# survives restarts/deploys (no spurious KEY_ROTATED). Unset master = ephemeral.
SERVER_KEYPAIR_PATH=/data/server-keypair.json

# Master encryption key for saved-connection profiles.
# - REQUIRED for the feature. If unset, /api/saved-connections returns 503.
# - Must be base64-encoded ≥ 32 random bytes. Generate: openssl rand -base64 48
# - Rotating this value INVALIDATES all existing saved profiles (cannot decrypt).
# - File leak alone is safe (no key); .env leak alone is safe (no ciphertext);
#   only a full server compromise (both) lets an attacker decrypt.
VAULT_MASTER_SECRET=

# Optional: previous master, decrypt-only, during a key rotation. Set this to the
# OLD value when you change VAULT_MASTER_SECRET so existing saved profiles still
# decrypt. Re-saving migrates them to the new key; remove once fully migrated.
VAULT_MASTER_SECRET_OLD=

# ---- Redis (shared state backend) ----
# When set, rate-limit + confirm-tokens + (vault-encrypted) connection records
# live in Redis → survive app restart + enable multi-instance. Unset = in-memory.
# docker-compose injects redis://redis:6379 automatically; override here if external.
# REDIS_URL=redis://redis:6379
REDIS_PREFIX=dbm:

# ---- App branding ----
NEXT_PUBLIC_APP_NAME=DatabaseManager
